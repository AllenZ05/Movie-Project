rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    // Watchlist rules
    // Note: multiple allow statements are OR'ed, so ownership and data
    // validation must be combined into a single condition
    match /watchlists/{userEmail} {
      allow read: if isOwner(userEmail);
      allow write: if isOwner(userEmail) &&
                     request.resource.data.keys().hasOnly(['movies']) &&
                     request.resource.data.movies is list;
    }

    // Watch history rules
    match /watchHistory/{userEmail} {
      allow read: if isOwner(userEmail);
      allow write: if isOwner(userEmail) &&
                     request.resource.data.keys().hasOnly(['watched']) &&
                     request.resource.data.watched is list;
    }

    // Block access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}