rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    // Cart collection rules
    // Note: multiple allow statements are OR'ed, so ownership and data
    // validation must be combined into a single condition
    match /carts/{userEmail} {
      allow read: if isOwner(userEmail);
      allow write: if isOwner(userEmail) &&
                     request.resource.data.keys().hasOnly(['cart']) &&
                     request.resource.data.cart is list;
    }

    // Order history rules
    match /orders/{userEmail} {
      allow read: if isOwner(userEmail);
      allow write: if isOwner(userEmail) &&
                     request.resource.data.keys().hasOnly(['orders']) &&
                     request.resource.data.orders is list;
    }

    // Block access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}